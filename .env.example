# Primary: Gemini Flash (CareerCrafter AI spec)
# Copy this file to .env.local and add your key:
#   cp .env.example .env.local
GEMINI_API_KEY=your-gemini-key-here
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Fallback: OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Astra DB — vector store (required; no local fallback)
ASTRA_DB_API_ENDPOINT=https://<id>-<region>.apps.astra.datastax.com
ASTRA_DB_APPLICATION_TOKEN=AstraCS:...

# Vapi — voice mock interview (client-side; NEXT_PUBLIC_ exposes to browser)
NEXT_PUBLIC_VAPI_API_KEY=your-vapi-public-key
# Optional: use a pre-built assistant instead of the inline config
NEXT_PUBLIC_VAPI_ASSISTANT_ID=
